<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:conv="clr-namespace:ZCM.Converters"
    xmlns:controls="clr-namespace:ZCM.Controls"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#111111"
    x:Class="ZCM.MainPage">

    <ContentPage.Resources>
        <conv:OnlineStatusColorConverter x:Key="OnlineStatusColorConverter"/>
    </ContentPage.Resources>

    <controls:DrawerHost x:Name="Drawer" DrawerWidth="240">
        <controls:DrawerHost.Drawer>
            <controls:SidebarView x:Name="Sidebar" />
        </controls:DrawerHost.Drawer>

        <controls:DrawerHost.Main>
            <Grid Padding="24"
                  ColumnDefinitions="2*,1*"
                  RowDefinitions="Auto,1.2*,1*,Auto"
                  RowSpacing="24"
                  ColumnSpacing="24">

                <!-- ☰ hamburger at the top, no separate bar -->
                <Button Grid.Row="0"
                        Grid.Column="0"
                        Text="☰"
                        WidthRequest="44"
                        HeightRequest="44"
                        FontSize="20"
                        BackgroundColor="#2A2A2A"
                        TextColor="White"
                        CornerRadius="12"
                        HorizontalOptions="Start"
                        Command="{Binding Source={x:Reference Drawer}, Path=ToggleCommand}" />

                <!-- NETWORK OVERVIEW -->
                <Frame Grid.Row="1"
                       Grid.Column="0"
                       BackgroundColor="#212121"
                       CornerRadius="18"
                       Padding="20">

                    <VerticalStackLayout Spacing="16">
                        <Label Text="Network Overview"
                               FontSize="18"
                               TextColor="White"
                               FontAttributes="Bold" />

                        <Grid ColumnDefinitions="150,*">
                            <GraphicsView
                                x:Name="PeerDonutView"
                                WidthRequest="140"
                                HeightRequest="140" />

                            <VerticalStackLayout Grid.Column="1" Spacing="6">
                                <Label Text="{Binding OnlineCount, StringFormat='Peers Online: {0}'}" TextColor="White"/>
                                <Label Text="{Binding OfflineCount, StringFormat='Peers Offline: {0}'}" TextColor="White"/>
                                <Label Text="{Binding MessagingPeersCount, StringFormat='Messaging Peers: {0}'}" TextColor="White"/>
                                <Label Text="{Binding FileSharingPeersCount, StringFormat='FileSharing Peers: {0}'}" TextColor="White"/>
                                <Label Text="{Binding AvailableModelsCount, StringFormat='Available Models: {0}'}" TextColor="White"/>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- ACTIVITY (spans row 1 and 2) -->
                <Frame Grid.Row="1"
                       Grid.Column="1"
                       Grid.RowSpan="2"
                       BackgroundColor="#212121"
                       CornerRadius="18"
                       Padding="20">

                    <VerticalStackLayout Spacing="12"
                                         VerticalOptions="Fill">

                        <Label Text="Activity"
                               FontSize="18"
                               TextColor="White"
                               FontAttributes="Bold"/>

                        <CollectionView ItemsSource="{Binding ActivityFeed}"
                                        SelectionMode="None"
                                        VerticalOptions="FillAndExpand">

                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame BackgroundColor="#2A2A2A"
                                           Padding="8"
                                           CornerRadius="10"
                                           Margin="0,4">
                                        <Label Text="{Binding}"
                                               FontSize="12"
                                               TextColor="#CCCCCC"/>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- RECENT CONVERSATIONS -->
                <Frame Grid.Row="2"
                       Grid.Column="0"
                       BackgroundColor="#212121"
                       CornerRadius="18"
                       Padding="20">

                    <VerticalStackLayout Spacing="12">
                        <Label Text="Recent Conversations"
                               FontSize="18"
                               TextColor="White"
                               FontAttributes="Bold"/>

                        <CollectionView ItemsSource="{Binding RecentConversations}"
                                        SelectionMode="None">

                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame BackgroundColor="#1A1A1A"
                                           Padding="14"
                                           CornerRadius="14"
                                           Margin="0,6">

                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="12">

                                            <BoxView WidthRequest="10"
                                                     HeightRequest="10"
                                                     CornerRadius="5"
                                                     VerticalOptions="Center"
                                                     Color="{Binding IsOnline, Converter={StaticResource OnlineStatusColorConverter}}"/>

                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="2">
                                                <Label Text="{Binding PeerName}"
                                                       FontAttributes="Bold"
                                                       TextColor="White"/>
                                                <Label Text="{Binding LastMessage}"
                                                       FontSize="12"
                                                       TextColor="#CCCCCC"
                                                       LineBreakMode="TailTruncation"/>
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- FILES SHARED -->
                <Frame Grid.Row="3"
                       Grid.Column="0"
                       BackgroundColor="#212121"
                       CornerRadius="18"
                       Padding="20"
                       HeightRequest="315">

                    <VerticalStackLayout Spacing="12">
                        <Label Text="{Binding SharedFilesCount, StringFormat='Files Shared ({0})'}"
                               FontSize="18"
                               TextColor="White"
                               FontAttributes="Bold" />

                        <CollectionView ItemsSource="{Binding SharedFiles}"
                                        SelectionMode="None"
                                        VerticalOptions="FillAndExpand"
                                        MaximumHeightRequest="240">

                            <CollectionView.EmptyView>
                                <Label Text="No shared files found (yet)"
                                       TextColor="#888888"
                                       Margin="0,6,0,0" />
                            </CollectionView.EmptyView>

                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame BackgroundColor="#1A1A1A"
                                           Padding="12"
                                           CornerRadius="12"
                                           Margin="0,4"
                                           HasShadow="False">

                                        <Grid ColumnDefinitions="*,Auto"
                                              RowDefinitions="Auto,Auto"
                                              RowSpacing="2"
                                              ColumnSpacing="10">

                                            <Label Grid.Row="0" Grid.Column="0"
                                                   Text="{Binding FileName}"
                                                   TextColor="White"
                                                   FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation" />

                                            <Label Grid.Row="0" Grid.Column="1"
                                                   Text="{Binding FileSizeText}"
                                                   TextColor="#AAAAAA"
                                                   FontSize="12"
                                                   HorizontalTextAlignment="End" />

                                            <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                   TextColor="#CCCCCC"
                                                   FontSize="11"
                                                   LineBreakMode="TailTruncation">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="From: " />
                                                        <Span Text="{Binding PeerName}" FontAttributes="Italic" />
                                                        <Span Text=" • " />
                                                        <Span Text="{Binding FileType}" TextTransform="Uppercase" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>

                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- TRUST & SECURITY -->
                <Frame Grid.Row="3"
                       Grid.Column="1"
                       BackgroundColor="#212121"
                       CornerRadius="18"
                       Padding="20"
                       HeightRequest="315">

                    <Grid RowDefinitions="Auto,Auto,Auto,*"
                          RowSpacing="6">

                        <Label Grid.Row="0" Text="Trust &amp; Security" FontSize="18" TextColor="White" FontAttributes="Bold"/>
                        <Label Grid.Row="1" Text="Network secret active" TextColor="#CCCCCC"/>
                        <Label Grid.Row="2" Text="{Binding TrustedGroupsCount, StringFormat='{}{0} Trusted groups enabled'}" TextColor="#CCCCCC"/>

                        <CollectionView Grid.Row="3"
                                        ItemsSource="{Binding TrustGroupLines}"
                                        SelectionMode="None"
                                        VerticalOptions="FillAndExpand"
                                        Margin="0,6,0,0">

                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame BackgroundColor="#2A2A2A"
                                           Padding="8"
                                           CornerRadius="10"
                                           Margin="0,4"
                                           HasShadow="False">
                                        <Label Text="{Binding}"
                                               FontSize="12"
                                               TextColor="#CCCCCC"/>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                        </CollectionView>

                    </Grid>
                </Frame>

            </Grid>
        </controls:DrawerHost.Main>
    </controls:DrawerHost>
</ContentPage>