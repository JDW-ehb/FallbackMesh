<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ZCM.Pages.GroupsPopup"
    BackgroundColor="#80000000">

    <Grid>
        <BoxView BackgroundColor="Transparent">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackdropTapped"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <Frame WidthRequest="700"
               Padding="20"
               CornerRadius="18"
               BackgroundColor="#1F1F1F"
               HasShadow="False"
               HorizontalOptions="Center"
               VerticalOptions="Center">

            <VerticalStackLayout Spacing="14">

                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Groups (Trust)"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White"/>
                    <Button Grid.Column="1"
                            Text="✕"
                            Clicked="OnCloseClicked"
                            BackgroundColor="#2A2A2A"
                            TextColor="White"
                            CornerRadius="10"
                            WidthRequest="36"
                            HeightRequest="36"/>
                </Grid>

                <Label Text="Enabled groups are trusted. You may sign your identity with multiple groups."
                       TextColor="#AAAAAA"
                       FontSize="12" />

                <CollectionView ItemsSource="{Binding Groups}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="12" CornerRadius="12" BackgroundColor="#2A2A2A" HasShadow="False">
                                <VerticalStackLayout Spacing="10">

                                    <Entry Text="{Binding Name}" TextColor="White" />

                                    <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="20">

                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="Enabled" TextColor="#CCCCCC" FontSize="12"/>
                                            <Switch IsToggled="{Binding IsEnabled}" />
                                        </HorizontalStackLayout>

                                        <HorizontalStackLayout Grid.Column="1" Spacing="6">
                                            <Label Text="Sign Identity" TextColor="#CCCCCC" FontSize="12"/>
                                            <Switch IsToggled="{Binding IsActiveLocal}" />
                                        </HorizontalStackLayout>

                                    </Grid>

                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Text="+ Add Group"
                        Clicked="OnAddGroupClicked"
                        BackgroundColor="#27AE60"
                        TextColor="White"
                        CornerRadius="12"/>

            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>