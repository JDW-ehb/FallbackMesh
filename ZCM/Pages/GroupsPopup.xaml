<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ZCM.Pages.GroupsPopup"
    BackgroundColor="#80000000">

    <Grid>
        <!-- Backdrop -->
        <BoxView BackgroundColor="Transparent">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackdropTapped"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Popup -->
        <Frame WidthRequest="700"
               MaximumHeightRequest="650"
               Padding="20"
               CornerRadius="18"
               BackgroundColor="#1F1F1F"
               HasShadow="False"
               HorizontalOptions="Center"
               VerticalOptions="Center">

            <VerticalStackLayout Spacing="14">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Groups (Trust)"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White"/>

                    <Button Grid.Column="1"
                            Text="✕"
                            Clicked="OnCloseClicked"
                            BackgroundColor="#2A2A2A"
                            TextColor="White"
                            CornerRadius="10"
                            WidthRequest="36"
                            HeightRequest="36"/>
                </Grid>

                <!-- Description -->
                <Label Text="Enabled groups are trusted. Peers sharing at least one enabled group may communicate."
                       TextColor="#AAAAAA"
                       FontSize="12" />

                <!-- Groups List -->
                <Grid RowDefinitions="*"
                      HeightRequest="400">
                    <CollectionView ItemsSource="{Binding Groups}"
                                SelectionMode="None">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>

                                <Frame Padding="12"
                                   CornerRadius="12"
                                   BackgroundColor="#2A2A2A"
                                   HasShadow="False">

                                    <VerticalStackLayout Spacing="10">

                                        <!-- Group Name -->
                                        <Entry Text="{Binding Name}"
                                           TextColor="White"
                                           Placeholder="Group Name" />

                                        <!-- Secret with Show Toggle -->
                                        <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="8">

                                            <Entry Grid.Column="0"
                                               Text="{Binding SecretHex}"
                                               IsPassword="True"
                                               TextColor="White"
                                               Placeholder="Group Secret (hex)"
                                               x:Name="SecretEntry"/>

                                            <Button Grid.Column="1"
                                                Text="👁"
                                                Clicked="OnToggleSecretClicked"
                                                BackgroundColor="#333333"
                                                TextColor="White"
                                                CornerRadius="8"
                                                WidthRequest="40"/>
                                        </Grid>

                                        <!-- Secret Actions -->
                                        <HorizontalStackLayout Spacing="8">

                                            <Button Text="Copy"
                                                Clicked="OnCopySecretClicked"
                                                BackgroundColor="#333333"
                                                TextColor="White"
                                                CornerRadius="8" />

                                            <Button Text="Regenerate"
                                                Clicked="OnRegenerateSecretClicked"
                                                BackgroundColor="#333333"
                                                TextColor="White"
                                                CornerRadius="8" />

                                        </HorizontalStackLayout>

                                        <!-- Enabled Switch -->
                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="Enabled"
                                               TextColor="#CCCCCC"
                                               FontSize="12" />
                                            <Switch IsToggled="{Binding IsEnabled}" />
                                        </HorizontalStackLayout>

                                    </VerticalStackLayout>
                                </Frame>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>

                <!-- Add Group -->
                <Button Text="+ Add Group"
                        Clicked="OnAddGroupClicked"
                        BackgroundColor="#27AE60"
                        TextColor="White"
                        CornerRadius="12"/>

            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>